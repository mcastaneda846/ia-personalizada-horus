OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL de Horus (perfil médico del usuario)
DATABASE_URL=postgresql://user:password@host/horus_db

# PostgreSQL base de conocimiento vectorial (proyecto Neon separado)
VECTOR_DATABASE_URL=postgresql://user:password@host/vectors_db?sslmode=require

# Ruta al archivo JSON de Firebase Admin SDK (nunca subir el JSON al repo)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Redis — Upstash con TLS (rediss://)
REDIS_URL=rediss://default:password@host.upstash.io:6379
SESSION_TTL_SECONDS=3600

PORT=3001
NODE_ENV=production

API_SECRET_KEY=minimo_16_caracteres_aqui
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
