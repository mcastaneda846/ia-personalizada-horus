# Google AI Studio
GOOGLE_AI_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemini-flash-latest
EMBEDDING_MODEL=gemini-embedding-001

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=horus_users

# Redis (sesiones en memoria)
REDIS_URL=redis://localhost:6379
SESSION_TTL_SECONDS=3600

# PostgreSQL de Horus (read + write para logs)
DATABASE_URL=postgresql://user:password@localhost:5432/horus_db

# App
PORT=3001
NODE_ENV=development

# Seguridad — token compartido con el equipo de Horus
INTERNAL_API_KEY=super_secret_internal_key
API_SECRET_KEY=super_secret_internal_key


# Firebase
FIREBASE_PROJECT_ID=tu_project_id
FIREBASE_CLIENT_EMAIL=tu_client_email
FIREBASE_PRIVATE_KEY="tu_private_key"
