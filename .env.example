# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── PostgreSQL — perfil médico (Neon o cualquier Postgres) ───────────────────
DATABASE_URL=postgresql://user:password@host/horus_db?sslmode=verify-full

# ── PostgreSQL — base de conocimiento vectorial ──────────────────────────────
VECTOR_DATABASE_URL=postgresql://user:password@host/vectors_db?sslmode=verify-full

# ── Firebase Admin ───────────────────────────────────────────────────────────
# PaaS (Railway, Render, etc.): pega aquí el contenido completo del JSON
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Local: ruta al archivo JSON en disco (una u otra, no las dos)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Redis / Upstash ──────────────────────────────────────────────────────────
REDIS_URL=rediss://default:password@host.upstash.io:6379
SESSION_TTL_SECONDS=3600

# ── ElevenLabs TTS ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_...

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Seguridad ────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
API_SECRET_KEY=minimo_32_caracteres_aleatorios_aqui

# ── CORS — orígenes permitidos separados por coma ────────────────────────────
ALLOWED_ORIGINS=https://tuapp.com,https://app.tuapp.com

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
